# Haftung_AI Environment Configuration

# LLM
GROQ_API_KEY=gsk_your_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Vector DB
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=haftung_chunks

# Embedding model
EMBEDDING_MODEL=BAAI/bge-large-en-v1.5

# App
APP_NAME=Haftung_AI
ENV=dev
LOG_LEVEL=INFO

# RAG
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K_RETRIEVAL=5
TOP_K_RERANK=20
VALIDATION_THRESHOLD=0.7
